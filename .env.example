# Copy to .env and fill in your values. Never commit .env.

# Bot token from Discord Developer Portal (Bot section)
DISCORD_TOKEN=your_bot_token_here
# Or use TOKEN=... if you prefer

# Application (client) ID from Discord Developer Portal (OAuth2 > General)
CLIENT_ID=your_application_id_here

# Your Discord server ID (right-click server icon → Copy ID; enable Developer Mode)
GUILD_ID=your_guild_id_here

# Your Discord user ID (for admin DMs / notifications)
ADMIN_USER_ID=your_user_id_here

# PostgreSQL: use the FULL External URL when running locally.
# On Render: Postgres service → Connect → "External Database URL".
# Host must look like: xxx.oregon-postgres.render.com (not just "dpg-xxx-a").
DATABASE_URL=postgres://user:password@hostname.oregon-postgres.render.com/dbname?sslmode=require

# Optional: Discord channel ID for ticket open/close logs
# LOG_CHANNEL_ID=

# Optional: comma-separated role IDs that get mentioned in new tickets
# SUPPORT_ROLE_IDS=id1,id2

# Optional: base URL for transcript viewer (e.g. https://your-app.onrender.com)
# TRANSCRIPT_BASE_URL=
# TRANSCRIPT_VIEW_KEY=

# Optional: GitHub Gist DB backups (logical JSON export). Runs every 12 hours if enabled.
# Create a fine-scoped token with access to edit the target gist.
# GIST_BACKUP_ENABLED=true
# GITHUB_GIST_ID=your_gist_id_here
# GITHUB_GIST_TOKEN=github_pat_xxx
#
# Optional: manual trigger endpoint (GET /backup/run?key=...)
# BACKUP_RUN_KEY=your_long_random_string

# Ticket category channel IDs: right‑click each category in Discord → Copy ID.
# Each option in the panel uses the matching category below. If missing, tickets are created with no category.
# CATEGORY_GENERAL_SUPPORT=123456789012345678
# CATEGORY_REPORT_USER=123456789012345679
# CATEGORY_ACCOUNT_RECOVERY=123456789012345680
# CATEGORY_PURCHASE_BILLING=123456789012345681
# CATEGORY_BADGE_APPLICATION=123456789012345682
